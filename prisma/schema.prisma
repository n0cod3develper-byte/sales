generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roles      Role[]   @relation("UserRoles")
  adminLogs  AdminLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
}

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
}

model Permission {
  id       String @id @default(uuid())
  resource String
  action   Action
  roles    Role[] @relation("RolePermissions")
}
model Service {
  id          String @id @default(uuid())
  title       String
  slug        String @unique
  description String
  imagePath   String?
}

model Product {
  id        String @id @default(uuid())
  title     String
  slug      String @unique
  imagePath String?
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String?
  published DateTime @default(now())
  imagePath String?
}

model Brand {
  id   String @id @default(uuid())
  name String @unique
  logo String?
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model Media {
  id        String @id @default(uuid())
  url       String
  type      String
  altText   String?
  uploaded  DateTime @default(now())
}

model Settings {
  id   String @id @default(uuid())
  data Json   @default("{}")
}
model AdminLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  resource  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
